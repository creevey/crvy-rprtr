{
  "name": "@creevey/playwright-reporter",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch build.ts & bun run --watch src/server.ts",
    "build": "bun build.ts",
    "start": "bun src/server.ts",
    "lint": "oxlint",
    "fmt": "oxfmt --write",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && bunx playwright test",
    "test:ui": "bun run build && bunx playwright test --ui",
    "example": "cd examples/playwright && bunx playwright test"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "postcss": "^8.5.8",
    "svelte": "^5.54.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "esbuild": "^0.27.4",
    "esbuild-svelte": "^0.9.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
