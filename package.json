{
  "name": "creevey-reporter",
  "private": true,
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build ./src/index.ts --target=browser --outdir=./dist",
    "start": "bun src/server.ts",
    "lint": "oxlint",
    "fmt": "oxfmt --write",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && bunx playwright test",
    "test:ui": "bun run build && bunx playwright test --ui",
    "example": "cd examples/playwright && bunx playwright test"
  },
  "dependencies": {
    "svelte": "^5.54.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "esbuild": "^0.27.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
